---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const featuredSkills = await getCollection('skills', ({ data }) => {
  return data.featured === true;
});
---

<Layout>
  <pre class="hero">‚ĖĎ‚Ėí‚Ėą‚ĖÄ‚ĖÄ‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖÄ‚ĖÄ‚ĖĄ‚ĖĎ‚Ėí‚Ėą‚ĖÄ‚ĖÄ‚ĖÄ‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖÄ‚ĖÄ‚Ėą‚ĖÄ‚ĖÄ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖÄ‚ĖÄ‚ĖÄ‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĄ‚ĖÄ‚ĖĎ‚ĖÄ‚Ėą‚ĖÄ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖÄ‚ĖÄ‚ĖÄ‚Ėą
‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĄ‚ĖĄ‚ĖĎ‚Ėí‚Ėą‚ĖĄ‚ĖĄ‚ĖÄ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚Ėí‚Ėą‚Ėí‚Ėą‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖÄ‚ĖÄ‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĄ‚ĖĄ‚ĖĎ‚Ėí‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖÄ‚ĖĄ‚ĖĄ
‚ĖĎ‚Ėí‚Ėą‚ĖĄ‚ĖĄ‚ĖÄ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚ĖĎ‚Ėí‚ĖÄ‚ĖĄ‚ĖÄ‚ĖĄ‚ĖÄ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėí‚Ėą‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĎ‚ĖĄ‚Ėą‚ĖĄ‚ĖĎ‚Ėí‚Ėą‚ĖĄ‚ĖĄ‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĄ‚ĖĄ‚Ėą‚ĖĎ‚Ėí‚Ėą‚ĖĄ‚ĖĄ‚ĖĄ‚Ėą</pre>
  <p>A curated collection of AI skills for Growth Engineers.</p>
  {featuredSkills.length > 0 && (
    <>
      <h2>Featured Skills</h2>
      <div class="skills-grid">
        {featuredSkills.map((skill) => (
          <a href={`/skills/${skill.data.slug}`} class="skill-card">
            <strong>{skill.data.slug}</strong>
            <em>by {skill.data.user}</em>
            <p>{skill.data.description}</p>
          </a>
        ))}
      </div>
    </>
  )}
  <p><a href="/skills">Browse all skills &rarr;</a></p>
</Layout>

<style>
  .hero {
    font-family: monospace;
    font-size: 0.875rem;
    line-height: 1;
    overflow: hidden;
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .hero {
      font-size: 0.4rem;
    }
  }

  h2 {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .skill-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem 1.5rem;
    background: white;
    border: 1px solid oklch(92% 0.004 286.32);
    text-decoration: none;
    color: inherit;
  }

  .skill-card:hover {
    background: oklch(97% 0.004 286.32);
  }

  .skill-card strong {
    font-size: 1.1rem;
  }

  .skill-card p {
    opacity: 0.8;
  }

  @media (max-width: 640px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
