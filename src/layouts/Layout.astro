---
import { Font } from "astro:assets";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title, description = "A curated collection of AI skills for Growth Engineers." } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-commit-mono" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{title ? `${title} | Growth Skills` : "Growth Skills"}</title>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/skills">Skills</a>
      <a href="/topics">Topics</a>
    </nav>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} <a href="https://tyborowski.com" target="_blank" rel="noopener noreferrer">Kamil Tyborowski</a></p>
    </footer>
    <script
      defer
      src="/a.js"
      data-website-id="8e8062c6-7de1-4b8b-9181-41cbb94070d6"
      data-host-url="https://umami.growthskills.dev"
    ></script>
  </body>
</html>
